<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.nanobrain.ingest.gdrive</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__BRAIN_DIR__/.nanobrain/code/skills/brain-ingest/dispatch.sh</string>
    <string>gdrive</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>BRAIN_DIR</key><string>__BRAIN_DIR__</string>
    <key>NANOBRAIN_DIR</key><string>__BRAIN_DIR__/.nanobrain</string>
  </dict>
  <key>StartInterval</key><integer>7200</integer>
  <key>StandardOutPath</key><string>__BRAIN_DIR__/data/_logs/ingest.gdrive.log</string>
  <key>StandardErrorPath</key><string>__BRAIN_DIR__/data/_logs/ingest.gdrive.err</string>
</dict>
</plist>
