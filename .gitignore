# Secrets and machine-local state never enter the repo
.env
*.env
.env.*

# Sensitive sources (contracts, NDAs, medical, legal). Encrypted at rest, never committed.
data/_sensitive/

# Per-source watermarks (machine-local progress trackers)
data/**/.watermark
data/**/.distill-watermark

# Backup snapshots created before risky edits (per code/SAFETY.md M5)
code/_backup/

# OS / editor artifacts
.cache/
.DS_Store
.idea/
.vscode/
*.swp
*~

# nanobrain framework's own runtime state (logs, locks, watermarks)
data/_logs/
.capture.lock

# Node deps (mcp-server, remotion)
node_modules/
remotion/out/

# Smoke-test scratch files (copied next to node_modules at runtime)
code/mcp-server/_smoke-client.mjs
code/mcp-server/_edge-client.mjs

# Direct local overrides
*.local
*.local-backup-*
